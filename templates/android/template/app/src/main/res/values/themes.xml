<?xml version="1.0" encoding="UTF-8"?>
<resources>
	<style name="LimeAppMainThemeFullscreen" parent="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen">
		<!-- Ensure content draws behind the system bars -->
		<item name="android:windowDrawsSystemBarBackgrounds">true</item>

		<!-- Prevent swipe-to-dismiss behavior -->
		<item name="android:windowSwipeToDismiss">false</item>

		::if (ANDROID_DISPLAY_CUTOUT!="")::
		<!-- Enable drawing under the display cutout -->
		<item name="android:windowLayoutInDisplayCutoutMode">::ANDROID_DISPLAY_CUTOUT::</item>
		::end::

		<!-- Make the status bar transparent -->
		<item name="android:statusBarColor">@android:color/transparent</item>
	</style>

	<style name="LimeAppMainTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
		<!-- Ensure content draws behind the system bars -->
		<item name="android:windowDrawsSystemBarBackgrounds">true</item>

		<!-- Prevent swipe-to-dismiss behavior -->
		<item name="android:windowSwipeToDismiss">false</item>

		::if (ANDROID_DISPLAY_CUTOUT!="")::
		<!-- Enable drawing under the display cutout -->
		<item name="android:windowLayoutInDisplayCutoutMode">::ANDROID_DISPLAY_CUTOUT::</item>
		::end::

		<!-- Make the status bar transparent -->
		<item name="android:statusBarColor">@android:color/transparent</item>
	</style>
</resources>
